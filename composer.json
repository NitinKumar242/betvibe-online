{
    "name": "betvibe/betvibe",
    "description": "GenZ-focused betting platform with Telegram integration",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": ">=8.2",
        "vlucas/phpdotenv": "^5.5",
        "ratchet/pawl": "^0.4",
        "cboden/ratchet": "^0.4",
        "react/event-loop": "^1.3",
        "irazasyed/telegram-bot-sdk": "^3.0",
        "firebase/php-jwt": "^6.10",
        "guzzlehttp/guzzle": "^7.8",
        "monolog/monolog": "^3.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "squizlabs/php_codesniffer": "^3.8"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "cs-check": "phpcs --standard=PSR12 app/",
        "cs-fix": "phpcbf --standard=PSR12 app/"
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true
        },
        "audit": {
            "ignore": {
                "firebase/php-jwt": "*"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}