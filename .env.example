# BetVibe Environment Configuration
# Copy this file to .env and update with your actual values

# Application
APP_NAME=
APP_ENV=
APP_DEBUG=
APP_URL=
APP_SECRET=

# Database
DB_HOST=
DB_PORT=
DB_NAME=
DB_USER=
DB_PASS=

# WatchPay Payment Gateway
WATCHPAY_API_KEY=
WATCHPAY_SECRET=
WATCHPAY_WEBHOOK_SECRET=

# Telegram Bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=
TELEGRAM_BOT_USERNAME=
TELEGRAM_WEBHOOK_URL=

# Admin
ADMIN_USER_ID=

# VAPID (Web Push Notifications)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Security
JWT_SECRET=
ENCRYPTION_KEY=

# WebSocket Server
WS_PORT=
WS_HOST=

# Redis (optional, for caching)
REDIS_HOST=
REDIS_PORT=
REDIS_PASSWORD=

# Email (optional)
MAIL_HOST=
MAIL_PORT=
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME=

# Timezone
APP_TIMEZONE=
